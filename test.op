mut int size = 3;

for(mut int i = 1; i < size; i = i + 1) {
  for(mut int j = 1; j < size; j = j + 1) {
    mut int calculation = i * j;
    print(calculation);
  }
}

mut int num = 10;

if(num > 5) {
  print("Works");
} else if (num < 5) {
  print("Works");
} else {
  print("Works as well");
}

while(num < 20) {
  num = num + 1;
  print(num);
}
